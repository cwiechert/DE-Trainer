  {
    id: "delta-101",
    topic: "deltalake",
    track: "databricks",
    difficulty: "basico",
    type: "fill",
    prompt: "Completa el comando SQL que compacta los archivos pequeños de una tabla Delta para mejorar el rendimiento de lectura: <code>____ ventas</code>",
    accept: ["OPTIMIZE"],
    answerDisplay: "OPTIMIZE",
    explanation: "OPTIMIZE compacta muchos archivos pequeños en archivos mayores. Puede combinarse con ZORDER BY (col) para co-localizar datos por una columna de alta cardinalidad y mejorar el data skipping.",
    reference: "Documentación Databricks (OPTIMIZE)",
  },

  {
    id: "delta-102",
    topic: "deltalake",
    track: "databricks",
    difficulty: "intermedio",
    type: "fill",
    prompt: "Completa el comando que realiza un UPSERT (insertar/actualizar) en una tabla Delta: <code>____ INTO destino USING origen ON ... WHEN MATCHED THEN UPDATE ...</code>",
    accept: ["MERGE"],
    answerDisplay: "MERGE",
    explanation: "MERGE INTO permite upserts (y borrados) atómicos en una sola sentencia: actualiza filas que cumplen la condición e inserta las que no. Es la base de patrones CDC y SCD Tipo 2.",
    reference: "Documentación Databricks (Delta MERGE)",
  },

  {
    id: "delta-103",
    topic: "deltalake",
    track: "databricks",
    difficulty: "intermedio",
    type: "fill",
    prompt: "Completa el comando que elimina archivos de datos obsoletos ya no referenciados por una tabla Delta (retención por defecto de 7 días): <code>____ ventas</code>",
    accept: ["VACUUM"],
    answerDisplay: "VACUUM",
    explanation: "VACUUM borra archivos obsoletos más antiguos que el umbral de retención (7 días por defecto). Reducir la retención por debajo de 7 días puede romper el time travel y lecturas concurrentes. Suele ejecutarse tras OPTIMIZE.",
    reference: "Documentación Databricks (VACUUM)",
  },

